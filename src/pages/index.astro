---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import Badge from "../components/Badge.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const last_posts = posts.slice(0, 3);

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const category_label_class =
  "text-xs font-bold tracking-[0.06em] uppercase whitespace-nowrap";
const skills_cell_class = "text-gray-600 text-[13.5px]";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-8 mt-5">
    <div class="text-5xl font-bold">I'm Manuel</div>
    <div class="text-3xl py-3 font-bold">Computer Vision Engineer</div>
    <div class="py-2">
      <text class="text-lg">
        I am a Computer Vision Engineer with experience in deep learning, data
        pipelines, and model deployment across edge and cloud environments.
        Skilled in segmentation, object detection, classification and anomaly
        detection.
      </text>
    </div>
  </div>

  <div class="text-3xl w-full font-bold mb-4">Skills</div>

  <table
    class="w-full border-separate border-spacing-0 rounded-xl overflow-hidden mb-10 shadow-[0_1px_3px_rgba(0,0,0,0.06),0_0_0_1px_rgba(0,0,0,0.05)]"
  >
    <thead
      class="[&_th]:px-5 [&_th]:py-3 [&_th]:text-[11px] [&_th]:font-semibold [&_th]:tracking-widest [&_th]:uppercase [&_th]:text-gray-500 [&_th]:bg-gray-50 [&_th]:border-b [&_th]:border-gray-200 [&_th]:text-left"
    >
      <tr>
        <th class="w-[150px]">Category</th>
        <th class="w-[38%]">Tools</th>
        <th>Skills</th>
      </tr>
    </thead>
    <tbody
      class="[&_tr]:transition-colors [&_tr]:duration-[120ms] [&_tr:nth-child(even)]:bg-gray-50 [&_tr:hover]:bg-gray-100 [&_tr:not(:last-child)_td]:border-b [&_tr:not(:last-child)_td]:border-gray-100 [&_td]:px-5 [&_td]:py-3 [&_td]:align-top [&_td]:text-sm [&_td]:leading-[1.6]"
    >
      <tr>
        <td><span class={category_label_class}>Programming</span></td>
        <td>
          <Badge>Python</Badge>
          <Badge>C++</Badge>
        </td>
        <td class={skills_cell_class}>OOP, Multiprocessing</td>
      </tr>
      <tr>
        <td><span class={category_label_class}>Classical Vision</span></td>
        <td>
          <Badge>OpenCV</Badge>
        </td>
        <td class={skills_cell_class}>Image Processing, Feature Extraction</td>
      </tr>
      <tr>
        <td><span class={category_label_class}>3D Vision</span></td>
        <td>
          <Badge>Open3D</Badge>
        </td>
        <td class={skills_cell_class}
          >Camera Calibration, Multi-View Geometry, Stereo Vision, Bird's-eye
          View, Visual Odometry, Pose Estimation, Epipolar Geometry, Simulation</td
        >
      </tr>

      <tr>
        <td><span class={category_label_class}>Deep Learning</span></td>
        <td>
          <Badge>PyTorch</Badge>
          <Badge>PyTorch Lightning</Badge>
          <Badge>YOLO</Badge>
          <Badge>SAM2</Badge>
          <Badge>PyTorch Metric Learning</Badge>
          <Badge>Anomalib</Badge>
          <Badge>HF Transformers</Badge>
          <Badge>FAISS</Badge>
        </td>
        <td class={skills_cell_class}
          >Object Detection, Segmentation, Anomaly Detection, Classification,
          Deep Metric Learning, Model Evaluation (precision, recall, F1, AP)</td
        >
      </tr>

      <tr>
        <td
          ><span class={category_label_class}
            >Deployment &amp; Optimization</span
          ></td
        >
        <td>
          <Badge>TensorRT</Badge>
          <Badge>ONNX</Badge>
          <Badge>DeepStream</Badge>
          <Badge>Docker</Badge>
          <Badge>AWS</Badge>
          <Badge>Azure</Badge>
          <Badge>RunPod</Badge>
          <Badge>Vast.ai</Badge>
          <Badge>NVIDIA Nsight Systems</Badge>
        </td>
        <td class={skills_cell_class}
          >Model Serving, Containerized Deployment, Edge Inference, Pipeline
          Deployment, Serverless GPU Inference, Quantization, Pruning, FP16 /
          INT8 Inference, Inference Benchmarking, Latency Profiling</td
        >
      </tr>

      <tr>
        <td><span class={category_label_class}>Embedded &amp; Edge</span></td>
        <td>
          <Badge>Jetson Orin</Badge>
          <Badge>Raspberry Pi</Badge>
          <Badge>OAK-D Lite</Badge>
        </td>
        <td class={skills_cell_class}
          >RTSP, GStreamer Pipeline Development, Multi-stream Processing, Batch
          Processing, Video Analytics</td
        >
      </tr>

      <tr>
        <td><span class={category_label_class}>Tracking</span></td>
        <td>
          <Badge>SORT</Badge>
          <Badge>ByteTrack</Badge>
          <Badge>DeepSORT</Badge>
          <Badge>TrackEval</Badge>
        </td>
        <td class={skills_cell_class}
          >Multi-object Tracking, Tracklet Association, Kalman Filtering,
          Tracking Evaluation (HOTA, MOTA, IDF1)</td
        >
      </tr>

      <tr>
        <td><span class={category_label_class}>ML Experimentation</span></td>
        <td>
          <Badge>Weights &amp; Biases</Badge>
          <Badge>Optuna</Badge>
        </td>
        <td class={skills_cell_class}
          >Hyperparameter Tuning, Run Comparison, Metric Visualization</td
        >
      </tr>

      <tr>
        <td><span class={category_label_class}>Data Pipeline</span></td>
        <td>
          <Badge>Albumentations</Badge>
          <Badge>CVAT</Badge>
          <Badge>LabelMe</Badge>
          <Badge>FiftyOne</Badge>
          <Badge>Roboflow</Badge>
          <Badge>NumPy</Badge>
          <Badge>Pandas</Badge>
          <Badge>Matplotlib</Badge>
          <Badge>Apache Airflow</Badge>
        </td>
        <td class={skills_cell_class}
          >Workflow Automation, Data Curation, Deduplication, Model-assisted
          Verification, Format Conversion (COCO, DAVIS, YOLO)</td
        >
      </tr>

      <tr>
        <td
          ><span class={category_label_class}>Robotics &amp; Simulation</span
          ></td
        >
        <td>
          <Badge>ROS2</Badge>
          <Badge>Webots</Badge>
          <Badge>Exudyn</Badge>
        </td>
        <td class={skills_cell_class}
          >Robotics Simulation, Multibody Dynamics</td
        >
      </tr>
      <tr>
        <td><span class={category_label_class}>Development</span></td>
        <td>
          <Badge>Linux</Badge>
          <Badge>Git</Badge>
          <Badge>Pytest</Badge>
          <Badge>MyPy</Badge>
        </td>
        <td class={skills_cell_class}
          >Version Control, Shell Scripting, Unit Testing, Static Type Checking,
          Debugging</td
        >
      </tr>
    </tbody>
  </table>

  <div class="text-3xl w-full font-bold mb-2 mt-10">Projects</div>

  {
    projects.map((project) => (
      <>
        <HorizontalCard
          title={project.data.title}
          img={project.data.heroImage}
          desc={project.data.description}
          url={"/projects/" + createSlug(project.data.title, project.slug)}
          target="_self"
          badge={project.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }

  <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
